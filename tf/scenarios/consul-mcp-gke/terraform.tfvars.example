# =============================================================================
# terraform.tfvars.example
# Copy to terraform.tfvars and fill in your values.
# NEVER commit terraform.tfvars — it contains sensitive values.
# =============================================================================

# ---- GCP ----
gcp_project_id = "your-gcp-project-id"
gcp_region     = "us-central1"
gcp_zone       = "us-central1-a"
environment    = "dev"

# ---- HCP ----
# Create a service principal in HCP portal → Access control → Service principals.
# Do NOT put `hcp_client_secret` in this file. Provide it via env var:
#   export TF_VAR_hcp_client_secret='...'
hcp_client_id  = "your-hcp-client-id"
hcp_hvn_cidr   = "172.25.16.0/20" # Must not overlap GCP subnets
hcp_vault_tier = "plus_small"

# ---- Network ----
subnet_cidr   = "10.128.64.0/24"
pods_cidr     = "10.128.65.0/22"
services_cidr = "10.128.69.0/24"

# ---- Consul ----
datacenter             = "dc1"
consul_instance_count  = 1                    # Use 3 or 5 for production
consul_bootstrap_token = "REPLACE-WITH-UUID"  # Generated by: task token:ensure

# ---- GKE ----
gke_cluster_name  = "vault-mcp-cluster"
gke_node_count    = 2
gke_machine_type  = "e2-standard-4"
helm_chart_version = "1.9.2"

# Phase gate: set to true after phase 1 (GKE cluster created).
# No endpoint or CA cert needed — both are auto-discovered from GCP.
gke_cluster_ready            = false
gke_cluster_private_endpoint = ""   # Fill after phase 1: gcloud container clusters describe ... --format='value(privateClusterConfig.privateEndpoint)'
token_reviewer_jwt           = ""   # Fill after phase 2: task vault:reviewer-jwt

# gke_authorized_cidrs only takes effect when gke_enable_master_authorized_networks = true.
# Default deployment leaves the master endpoint open to the internet because HCP Vault
# Public Tier has no stable egress IPs to allowlist (see CLAUDE.md "Architectural gap").
# To restrict: set the flag below to true and include both operator IP(s) and HCP egress
# CIDRs (or stand up HVN→VPC peering and switch kubernetes_host to the private endpoint).
gke_authorized_cidrs = [
  { cidr = "YOUR_IP/32", name = "operator-workstation" },
]
gke_enable_master_authorized_networks = false

# ---- LLM ----
llm_provider     = "anthropic"
llm_model        = "claude-sonnet-4-6"
anthropic_api_key = "sk-ant-..."  # Your Anthropic API key

# ---- MCP Agents ----
mcp_replicas        = 2
mcp_image_tag       = "latest"
mcp_ttyd_credential = "admin:CHANGE_THIS_PASSWORD"
allowed_ingress_cidrs = ["YOUR_OFFICE_IP/32"]  # Restrict in production!

# ---- Vault Users ----
vault_users = {
  alice = { password = "CHANGE_ME", policies = ["operator-policy"] }
  bob   = { password = "CHANGE_ME", policies = ["analyst-policy"]  }
  carol = { password = "CHANGE_ME", policies = ["viewer-policy"]   }
}
